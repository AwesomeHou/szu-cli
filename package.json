{
  "name": "szu-cli",
  "version": "0.1.0-alpha.1",
  "private": false,
  "description": "Agent-friendly CLI for Shenzhen University web services.",
  "type": "module",
  "bin": {
    "szu": "src/cli.js"
  },
  "files": [
